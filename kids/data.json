      "titleHi": "चंदा मामा दूर के",
      "titleEn": "Chanda Mama Door Ke",
      "emoji": "🌙",
      "lyrics": [
        { "hi": "चंदा मामा दूर के,", "en": "Chanda mama door ke,", "tr": "Uncle Moon lives far away," },
        { "hi": "पुए पकाएं बूर के।", "en": "Puye pakayein boor ke.", "tr": "He cooks sweet cakes." },
        { "hi": "आप खाएं थाली में,", "en": "Aap khayein thaali mein,", "tr": "He eats them from a plate," },
        { "hi": "मुन्ने को दें प्याली में।", "en": "Munne ko dein pyaali mein.", "tr": "And gives it to the baby in a cup." },
        { "hi": "प्याली गई टूट, मामा गए रूठ!", "en": "Pyaali gayi toot, mama gaye rooth!", "tr": "The cup broke, and Uncle Moon got angry!" }
      ]
    },
    {
      "id": "butterfly",
      "titleHi": "तितली उड़ी",
      "titleEn": "Titli Udi",
      "emoji": "🦋",
      "lyrics": [
        { "hi": "तितली उड़ी, बस पर चढ़ी,", "en": "Titli udi, bus par chadi,", "tr": "The butterfly flew and got on the bus," },
        { "hi": "सीट ना मिली तो रोने लगी।", "en": "Seat na mili to rone lagi.", "tr": "She did not find a seat, so she started crying." },
        { "hi": "ड्राइवर ने बोला आजा मेरे पास,", "en": "Driver ne bola aaja mere paas,", "tr": "The driver said, \"Come sit near me,\"" },
        { "hi": "तितली बोली हट बदमाश,", "en": "Titli boli hat badmaash,", "tr": "The butterfly replied, \"Go away, naughty,\"" },
        { "hi": "मेरा घर है पास!", "en": "Mera ghar hai paas!", "tr": "My house is close by!\"" }
      ]
    },
    {
      "id": "horse",
      "titleHi": "लकड़ी की काठी",
      "titleEn": "Lakdi Ki Kathi",
