      "titleHi": "मछली जल की रानी है",
      "titleEn": "Machhli Jal Ki Rani Hai",
      "emoji": "🐠",
      "lyrics": [
        { "hi": "मछली जल की रानी है,", "en": "Machhli jal ki rani hai,", "tr": "The fish is the queen of the water," },
        { "hi": "जीवन उसका पानी है।", "en": "Jeevan uska paani hai.", "tr": "Her life is water itself." },
        { "hi": "हाथ लगाओ तो डर जाएगी,", "en": "Haath lagao to dar jayegi,", "tr": "Touch her, and she will get scared," },
        { "hi": "बाहर निकालो तो मर जाएगी।", "en": "Baahar nikalo to mar jayegi.", "tr": "Take her out, and she will die." }
      ]
    },
